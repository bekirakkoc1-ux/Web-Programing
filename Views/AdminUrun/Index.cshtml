@model List<Eticaretmvc.Models.Urun>

<h2>Admin Ürün Paneli</h2>

<a asp-action="Create" class="btn btn-success">Yeni Ürün</a>

<table class="table">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Fiyat</th>
            <th>Kategori</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Ad</td>
                <td>@item.Fiyat ₺</td>
                <td>@item.Kategori?.Ad</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Düzenle</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
    <button type="submit" class="btn btn-danger" onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?')">Sil</button>
</form>
                </td>
            </tr>
        }
    </tbody>
</table>
