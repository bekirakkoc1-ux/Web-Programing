@model Eticaretmvc.Models.Urun

<h2>Yeni Ürün Ekle</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label asp-for="Ad" class="control-label">Ürün Adı</label>
        <input asp-for="Ad" class="form-control" />
        <span asp-validation-for="Ad" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Fiyat" class="control-label">Fiyat</label>
        <input asp-for="Fiyat" class="form-control" />
        <span asp-validation-for="Fiyat" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Aciklama" class="control-label">Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control"></textarea>
        <span asp-validation-for="Aciklama" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="KategoriId" class="control-label">Kategori</label>
        <select asp-for="KategoriId" class="form-control" asp-items="ViewBag.Kategoriler"></select>
        <span asp-validation-for="KategoriId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Ürün Fotoğrafı</label>
        <input type="file" name="resimDosyasi" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Ekle</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
