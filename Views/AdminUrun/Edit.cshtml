@model Eticaretmvc.Models.Urun

<h2>Ürün Güncelle</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Ad" class="control-label"></label>
        <input asp-for="Ad" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Fiyat" class="control-label"></label>
        <input asp-for="Fiyat" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Aciklama" class="control-label"></label>
        <textarea asp-for="Aciklama" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label asp-for="KategoriId" class="control-label">Kategori</label>
        <select asp-for="KategoriId" class="form-control" asp-items="ViewBag.Kategoriler"></select>
    </div>

    <div class="form-group">
        <label>Mevcut Resim</label><br />
        @if (!string.IsNullOrEmpty(Model.ResimYolu))
        {
            <img src="@Model.ResimYolu" alt="Ürün Görseli" width="150" class="mb-2" />
        }
    </div>

    <div class="form-group">
        <label>Yeni Resim Yükle (İsteğe Bağlı)</label>
        <input type="file" name="resimDosyasi" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Güncelle</button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
