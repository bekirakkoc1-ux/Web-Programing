@model IEnumerable<Eticaretmvc.Models.Kategori>

<h2>Kategoriler</h2>

<a asp-action="Create" class="btn btn-success mb-3">+ Yeni Kategori</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th style="width: 150px;">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var kategori in Model)
        {
            <tr>
                <td>@kategori.Ad</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@kategori.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@kategori.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
