@model Eticaretmvc.Models.Urun

<h2>Yeni Ürün Ekle</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label asp-for="Ad" class="control-label"></label>
        <input asp-for="Ad" class="form-control" />
        <span asp-validation-for="Ad" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Fiyat" class="control-label"></label>
        <input asp-for="Fiyat" class="form-control" />
        <span asp-validation-for="Fiyat" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Aciklama" class="control-label"></label>
        <textarea asp-for="Aciklama" class="form-control"></textarea>
        <span asp-validation-for="Aciklama" class="text-danger"></span>
    </div>

    
    <div class="form-group">
    <label asp-for="ResimYolu" class="control-label"></label>
    <input asp-for="ResimYolu" class="form-control" />
    <span asp-validation-for="ResimYolu" class="text-danger"></span>
</div>


    <div class="form-group">
        <label asp-for="KategoriId">Kategori</label>
        <select asp-for="KategoriId" asp-items="ViewBag.Kategoriler" class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
</form>
