@model IEnumerable<Eticaretmvc.Models.Kategori>

<h2>Kategori Listesi</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Yeni Kategori</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var kategori in Model)
        {
            <tr>
                <td>@kategori.Ad</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@kategori.Id" class="btn btn-sm btn-warning">Güncelle</a>
                    <a asp-action="Delete" asp-route-id="@kategori.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
